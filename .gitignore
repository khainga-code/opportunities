WORK_STATE.md
ui/node_modules/
ui/public/
ui/resources/
ui/.hugo_build.lock
.superpowers/
bin/

# Stray Go build outputs when `go build ./...` is run from repo root
# (Go names the binary after the last path segment — here `cmd` — which
# collides with apps/*/cmd dirs). Negation re-allows the cmd/ directory
# that now hosts top-level binaries (cmd/seed-definitions etc).
/cmd
!/cmd/
/seed-definitions

# Bootstrap secrets — NEVER commit these
scripts/bootstrap/vault-seeds.env
.claude/

# Admin UI dist is copied in by the Dockerfile build stage; don't commit it.
apps/api/cmd/adminui/*
!apps/api/cmd/adminui/.gitkeep
